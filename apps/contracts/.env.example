# Network + deployer
ALCHEMY_BASE_SEPOLIA_URL=
DEPLOYER_PRIVATE_KEY=
ETHERSCAN_API_KEY=
FORK_RPC_URL=

# ─────────────────────────────────────────────────────────────
# Legacy single-vault deploy (Vault.sol)
# Used by: scripts/deploy-vault-legacy.ts
# ─────────────────────────────────────────────────────────────
KEEPERHUB_RELAYER_ADDRESS=
VAULT_ADMIN_ADDRESS=
VAULT_MAX_TRADE_SIZE_BPS=5000

# Router and token allowlists (comma-separated addresses)
VAULT_ALLOWED_ROUTERS=
VAULT_ALLOWED_TOKENS=

# Optional named token vars (used if VAULT_ALLOWED_TOKENS is empty)
VAULT_TOKEN_0G=
VAULT_TOKEN_LINK=
VAULT_TOKEN_UNI=
VAULT_TOKEN_USDC=
VAULT_TOKEN_WETH=

# ─────────────────────────────────────────────────────────────
# User-owned vault factory deploy (UserVault.sol + VaultFactory.sol)
# Used by: scripts/deploy-factory.ts
# Base Sepolia only
# ─────────────────────────────────────────────────────────────
# Default protocol fee bps for new vaults (0 for V1)
FACTORY_DEFAULT_FEE_BPS=0
# Max vaults per user address (default 3)
FACTORY_MAX_VAULTS_PER_USER=3
# Address that receives protocol fees on swaps (can be deployer)
FACTORY_PROTOCOL_FEE_RECEIVER=

# Reference router address (not required by script, but used by the system)
UNISWAP_ROUTER_ADDRESS=
