{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",

    "dev:local": "bun --env-file=.env.local run --hot src/index.ts",
    "dev:staging": "bun --env-file=.env.staging run --hot src/index.ts",
    "start": "bun run dist/index.mjs",
    "test": "bun test",
    "wipe:local": "bun run --env-file=.env.local scripts/db-wipe.ts",
    "wipe:staging": "bun run --env-file=.env.staging scripts/db-wipe.ts",
    "db:push:staging": "DRIZZLE_ENV_FILE=.env.staging bun x drizzle-kit push",
    "db:push:local": "DRIZZLE_ENV_FILE=.env.local bun x drizzle-kit push"
  },
  "dependencies": {
    "@0gfoundation/0g-ts-sdk": "^1.2.8",
    "@auto/api": "workspace:*",
    "@auto/contracts": "workspace:*",
    "@auto/env": "workspace:*",
    "@ethersproject/providers": "^5.8.0",
    "@google/genai": "^0.12.0",
    "@hono/zod-validator": "^0.7.6",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "@privy-io/node": "^0.16.0",
    "@uniswap/sdk-core": "^7.7.2",
    "bunqueue": "^2.8.0",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.2",
    "ethers": "^6.16.0",
    "hono": "catalog:",
    "postgres": "^3.4.9",
    "viem": "^2.39.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@auto/config": "workspace:*",
    "@types/bun": "catalog:",
    "drizzle-kit": "^0.31.10",
    "tsdown": "^0.21.9",
    "typescript": "catalog:"
  }
}
