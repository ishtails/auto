{
  "name": "auto",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@orpc/server": "^1.13.14",
      "@orpc/openapi": "^1.13.14",
      "@orpc/zod": "^1.13.14",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@orpc/client": "^1.13.14",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "web:dev": "turbo -F server dev:staging -F web dev",
    "server": "bun --filter server dev",
    "server:compile": "bun --filter server compile",
    "build": "turbo build",
    "hardhat": "./scripts/localnode.sh",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "check": "ultracite fix",
    "purge:modules": "./scripts/purge.sh",
    "db:push:staging": "bun --filter server push:staging",
    "db:push:local": "bun --filter server push:local",
    "wipe:local": "bun --filter server wipe:local",
    "wipe:staging": "bun --filter server wipe:staging"
  },
  "dependencies": {
    "@auto/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@auto/config": "workspace:*",
    "@biomejs/biome": "2.4.12",
    "@types/bun": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "ultracite": "7.6.2"
  },
  "packageManager": "bun@1.3.12"
}
